{
  "manifest_version": 3,
  "name": "StreetEasy Scraper",
  "version": "1.0.0",
  "description": "Captures property data from StreetEasy via WebSocket commands",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://streeteasy.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "StreetEasy Scraper"
  },
  "content_scripts": [
    {
      "matches": ["https://streeteasy.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
