MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=streeteasy

# Laravel API (server.py talks to the web app via HTTP)
LARAVEL_API_BASE=http://localhost:8000/api/scraper
SCRAPER_API_TOKEN=change-me-to-match-laravel-env

# Python server bind address & ports.
# Default 127.0.0.1 = localhost only.
# Use 0.0.0.0 to listen on all interfaces (LAN access).
# Use a specific IP to bind to one interface.
SERVER_HOST=127.0.0.1
WS_PORT=8765
HTTP_PORT=8766
